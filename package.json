{
  "name": "woocommerce-headless-nextjs",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "cross-env NODE_OPTIONS=--no-deprecation next dev --turbo",
    "dev:legacy": "next dev",
    "dev:debug": "NODE_OPTIONS='--inspect' next dev --turbo",
    "build": "next build",
    "build:analyze": "ANALYZE=true next build",
    "start": "next start",
    "lint": "eslint --cache --cache-location .next/cache/.eslintcache .",
    "lint:fix": "eslint --fix --cache --cache-location .next/cache/.eslintcache .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "type-check": "tsc --noEmit --incremental",
    "clean": "rimraf .next out .turbo node_modules/.cache",
    "clean:cache": "rimraf .next/cache .turbo",
    "clean:all": "npm run clean:cache && rimraf node_modules/.cache",
    "check": "npm run type-check && npm run lint && npm run format:check",
    "scan:setup": "node -e \"const os=require('os');const {execSync}=require('child_process');const isWin=os.platform()==='win32';execSync(isWin?'powershell -File scripts/setup-scan-tools.ps1':'bash scripts/setup-scan-tools.sh',{stdio:'inherit'})\"",
    "scan:unused": "node scripts/scan-unused.js",
    "scan:unused:fix": "node scripts/scan-unused.js --fix",
    "scan:purgecss": "npx purgecss --config purgecss.config.js",
    "scan:unimported": "npx unimported",
    "scan:depcheck": "npx depcheck --ignores=\"@types/*,eslint*,prettier,@next/*,@tailwindcss/*,postcss*,autoprefixer,babel-plugin-*,rimraf\""
  },
  "dependencies": {
    "@algolia/autocomplete-js": "^1.19.7",
    "@elastic/elasticsearch": "^9.2.0",
    "@hookform/resolvers": "^5.2.2",
    "@tanstack/react-query": "^5.90.7",
    "@types/dompurify": "^3.0.5",
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "@woocommerce/woocommerce-rest-api": "^1.0.2",
    "axios": "^1.14.0",
    "dompurify": "^3.3.1",
    "dotenv": "^17.3.1",
    "framer-motion": "^12.23.24",
    "graphql": "^16.12.0",
    "graphql-request": "^7.3.5",
    "he": "^1.2.0",
    "html-react-parser": "^5.2.10",
    "html2canvas": "^1.4.1",
    "html2pdf.js": "^0.12.1",
    "instantsearch.js": "^4.92.1",
    "ioredis": "^5.8.2",
    "isomorphic-dompurify": "^3.1.0",
    "jose": "^6.1.3",
    "js-cookie": "^3.0.5",
    "jspdf": "^3.0.4",
    "lodash.debounce": "^4.0.8",
    "lucide-react": "^0.552.0",
    "mysql2": "^3.15.3",
    "next": "^16.0.7",
    "next-auth": "^4.24.13",
    "next-seo": "^7.0.1",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-hook-form": "^7.66.0",
    "react-instantsearch": "^7.28.1",
    "react-pageflip": "^2.0.3",
    "sharp": "^0.34.5",
    "swiper": "^12.0.3",
    "swr": "^2.3.8",
    "tailwindcss-animate": "^1.0.7",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typesense": "^3.0.4",
    "typesense-instantsearch-adapter": "^3.0.2",
    "xss": "^1.0.15",
    "yup": "^1.7.1",
    "zustand": "^5.0.9"
  },
  "devDependencies": {
    "@next/bundle-analyzer": "^16.0.2",
    "@playwright/test": "^1.57.0",
    "@tailwindcss/postcss": "^4",
    "@types/google.maps": "^3.58.1",
    "@types/node": "^20.19.37",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "autoprefixer": "^10.4.21",
    "babel-plugin-react-compiler": "1.0.0",
    "cross-env": "^10.1.0",
    "eslint": "^9",
    "eslint-config-next": "16.0.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "postcss-lab-function": "^7.0.12",
    "postcss-preset-env": "^10.4.0",
    "prettier": "^3.6.2",
    "rimraf": "^6.0.1",
    "tailwindcss": "^4",
    "typescript": "^5.9.3"
  }
}
